NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/eminence_tasks?retryWrites=true&w=majority
ACCESS_TOKEN_SECRET=<use-a-strong-production-access-token-secret>
REFRESH_TOKEN_SECRET=<use-a-different-strong-production-refresh-token-secret>
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
CLIENT_URL=https://your-frontend-domain.com
